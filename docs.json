{
  "$schema": "https://mintlify.com/docs.json",
  "name": "RigidUI",
  "theme": "palm",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/fgrreloaded/rigidui"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fgrreloaded/rigidui"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "installation",
              "contributing"
            ]
          },
          {
            "group": "Creative Components",
            "pages": [
              "components/creative/data-reveal",
              "components/creative/draggable-canvas",
              "components/creative/text-shift",
              "components/creative/buttons"
            ]
          },
          {
            "group": "Core Components",
            "pages": [
              "components/core/access-manager",
              "components/core/currency-manager",
              "components/core/draggable-dashboard",
              "components/core/guided-tour",
              "components/core/image-loader",
              "components/core/location-picker",
              "components/core/smart-search"
            ]
          },
          {
            "group": "Form Components",
            "pages": [
              "components/forms/file-uploader",
              "components/forms/multi-step-form",
              "components/forms/password-strength",
              "components/forms/smart-form"
            ]
          },
          {
            "group": "Data Display",
            "pages": [
              "components/data/content-grid",
              "components/data/file-explorer",
              "components/data/infinite-scroll",
              "components/data/notification-center"
            ]
          },
          {
            "group": "Hooks",
            "pages": [
              "hooks/use-location"
            ]
          }
        ]
      }
    ]
  }
}
